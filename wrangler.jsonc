{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "tianxing-plc-selector",
  "compatibility_date": "2026-07-14",
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "aiflyenoch.xyz",
      "custom_domain": true
    },
    {
      "pattern": "www.aiflyenoch.xyz",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": ".",
    "html_handling": "auto-trailing-slash"
  }
}
